# MongoDB (use Atlas URI for production)
MONGODB_URI=mongodb://localhost:27017/naac_portal

# JWT Secret — use a long random string in production
JWT_SECRET=change_me_to_a_strong_secret

# Server port (Render sets this automatically)
PORT=5000

# Frontend URL for CORS (set to your Render frontend URL)
FRONTEND_URL=https://naac-frontend.onrender.com

# Cloudinary credentials (required for file uploads in production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
